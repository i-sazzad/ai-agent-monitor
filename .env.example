# Agent Monitor — Backend configuration
# Copy this file to .env and fill in the values before starting the server.

# Secret token that capture agents use to POST data to /ingest — required
INGEST_TOKEN=change-me-random-secret

# Dashboard login token — required
ADMIN_TOKEN=change-me-random-secret

# How many days of interaction data to retain (default: 90)
RETENTION_DAYS=90

# Account-level session limits (shared pool across all coders).
# Set to your actual plan limits. 0 = not configured (hidden in dashboard).
CLAUDE_DAILY_LIMIT=0
CLAUDE_WEEKLY_LIMIT=0
OPENCODE_DAILY_LIMIT=0
OPENCODE_WEEKLY_LIMIT=0
