# Agent Monitor — Capture Agent configuration
# Copy this file to .env in the same folder as agent.js and fill in the values.

# URL of the monitor backend — required
INGEST_URL=http://192.168.x.x:4319

# Ingest token (from the backend .env) — required
INGEST_TOKEN=

# Override the coder display name (default: OS login username)
# CODER_NAME=john

# Claude Code account email — shown in dashboard Account column (optional)
# CLAUDE_ACCOUNT_EMAIL=john@company.com

# OpenCode account email — shown in dashboard Account column (optional)
# OPENCODE_ACCOUNT_EMAIL=john@company.com
